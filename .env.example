# ──────────────────────────────────────────────
# CareSuite Hospital PMS — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ──────────────────────────────────────────────

# ── Backend Server ──────────────────────────────
PORT=5000
NODE_ENV=development

# ── MySQL Database ───────────────────────────────
DB_NAME=hospital_pms
DB_USER=hospital_user
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_HOST=localhost
DB_PORT=3306

# ── JWT Secrets ──────────────────────────────────
# Generate with: openssl rand -hex 64
ACCESS_TOKEN_SECRET=CHANGE_ME_access_token_secret_min_64_chars
REFRESH_TOKEN_SECRET=CHANGE_ME_refresh_token_secret_min_64_chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ── CORS ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── MySQL Root (for docker-compose only) ─────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password
MYSQL_DATABASE=hospital_pms
MYSQL_USER=hospital_user
MYSQL_PASSWORD=CHANGE_ME_strong_password_here

# ── Vault (HashiCorp) ────────────────────────────
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=CHANGE_ME_vault_root_token
VAULT_DEV_ROOT_TOKEN_ID=CHANGE_ME_vault_root_token

# ── AWS (for Terraform) ──────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# ── Terraform / EKS ──────────────────────────────
TF_VAR_cluster_name=hospital-pms-eks
TF_VAR_environment=production
TF_VAR_vpc_cidr=10.0.0.0/16

# ── GitHub Actions / CI ──────────────────────────
# Set these as GitHub repo secrets, NOT in this file:
# DOCKER_HUB_USERNAME
# DOCKER_HUB_TOKEN
# SLACK_WEBHOOK_URL
# AWS_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY
# KUBECONFIG (base64 encoded)
